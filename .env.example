# ─────────────────────────────────────────────────────────────────────────────
# Ageman Bespoke — Environment Variables
# Copy this file to .env.local for local development
# ─────────────────────────────────────────────────────────────────────────────

# Supabase PostgreSQL (Vercel uses connection pooling via pgBouncer for DATABASE_URL)
# Go to: Supabase → Settings → Database → Connection String → Transaction (pooler)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used for Prisma migrations only)
# Go to: Supabase → Settings → Database → Connection String → Session (direct)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
